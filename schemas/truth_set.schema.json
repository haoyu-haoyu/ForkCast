{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policy-impact-sandbox.local/schemas/truth_set.schema.json",
  "title": "Policy Truth Set",
  "type": "object",
  "required": ["case_id", "case_name", "facts"],
  "additionalProperties": true,
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "case_name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "verification_policy": { "type": "string" },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "requested_item", "fact", "confidence_status", "sources"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "type": "string" },
          "requested_item": { "type": "string" },
          "fact": { "type": "string" },
          "value": { "type": ["object", "null"] },
          "confidence_status": { "enum": ["已确认", "待核实", "未找到"] },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "quote"],
              "additionalProperties": true,
              "properties": {
                "source_name": { "type": "string" },
                "source_type": { "type": "string" },
                "url": { "type": "string", "minLength": 1 },
                "quote": { "type": "string" }
              }
            }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
