# Project LLM provider configuration for extraction, agent generation, and reports.
# DeepSeek is OpenAI-compatible. API keys must stay in local environment only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional generic OpenAI-compatible overrides. These take precedence over DeepSeek vars.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60

# OASIS stretch only. Do not set unless explicitly validating live OASIS later.
OPENAI_API_KEY=
OASIS_RUN_LIVE=0

# Runtime mode: auto | oasis | mock
SIMULATION_MODE=auto

# Cost and scale guards.
MAX_AGENTS=50
MAX_ROUNDS=3
MAX_LLM_CALLS_PER_RUN=100

# Kaspa integration, used in Phase 4 only.
# Default MVP path prepares a local verification payload and does not broadcast.
KASPA_NETWORK=testnet-10
KASPA_RPC_URL=
KASPA_WALLET_FILENAME=
KASPA_WALLET_SECRET=
KASPA_MNEMONIC=
KASPA_RECIPIENT_ADDRESS=
