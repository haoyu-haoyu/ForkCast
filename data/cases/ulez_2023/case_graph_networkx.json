    {
      "id": "assumption:assumption_air_quality_improvement_sustained",
      "label": "The reduction in NOx emissions and NO2 concentrations observed in the first 6 months will be sustained or increase over time.",
      "kind": "assumption"
    },
    {
      "id": "assumption:assumption_compliance_trend_continues",
      "label": "The observed compliance rate increase from 91.6% to 96.2% will continue or stabilize at a high level beyond 6 months.",
      "kind": "assumption"
    },
    {
      "id": "assumption:assumption_public_opinion_stable",
      "label": "Public opinion distribution (47% support, 42% oppose London-wide) remains stable over the simulation period.",
